# Canary configuration — minimal live run to verify broker pipeline end-to-end.
# See LIVE_RUNBOOK.md §2 for the full canary procedure before using this file.
#
# Usage:
#   cp canary.env.example .env
#   # Fill in your live API credentials below, then:
#   python main.py --safety-check   # must be GREEN
#   python main.py --live-shadow    # dry run against live account
#   python main.py --mode open      # actual canary trade

# ── Live Alpaca credentials ───────────────────────────────────────────────────
ALPACA_API_KEY=your_live_alpaca_api_key_here
ALPACA_SECRET_KEY=your_live_alpaca_secret_key_here
ALPACA_BASE_URL=https://api.alpaca.markets
TRADING_MODE=live

# ── Required live trading acknowledgement ─────────────────────────────────────
LIVE_CONFIRM=I-ACCEPT-REAL-MONEY-RISK

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Canary risk limits — very conservative ────────────────────────────────────
# One position maximum. Orders capped at $20 notional.
# Total deployment for the day capped at $20.
# If the bot loses $20 the experiment drawdown cap stops all future buys.
SMALL_ACCOUNT_MODE=true
MAX_POSITIONS=1
MAX_SINGLE_ORDER_USD=20
MAX_DAILY_NOTIONAL_USD=20
MAX_DEPLOYED_USD=20
MAX_EXPERIMENT_DRAWDOWN_USD=20

# Higher confidence threshold — only act on strong signals during canary.
MIN_CONFIDENCE=8

# ── Email notifications (optional — fill in or leave blank) ───────────────────
# EMAIL_FROM=your_gmail@gmail.com
# EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_TO=your_gmail@gmail.com
# EMAIL_RECIPIENTS=You:your_gmail@gmail.com
