# Copy this file to .env and fill in your values

# Alpaca API - get these at https://app.alpaca.markets
# Default is paper trading (safe for testing)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# For paper trading (default, recommended to start):
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# For LIVE trading (only when ready - real money):
# ALPACA_BASE_URL=https://api.alpaca.markets

# Anthropic API - get this at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email notifications (Gmail)
EMAIL_FROM=your_gmail@gmail.com
EMAIL_TO=your_gmail@gmail.com
EMAIL_CC=friend1@gmail.com,friend2@gmail.com  # optional — daily summary + weekly review only
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Discord alerts (optional — get webhook URL from Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here
