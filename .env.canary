# Canary environment — controlled single-symbol test before full live experiment.
# Copy to .env (or export) before running the canary procedure.
# Restores the full £150 profile (.env) after successful canary completion.
#
# Purpose: confirm the complete buy → fill → stop pipeline works end-to-end
# with a tiny cap ($10) so a mistake costs at most $10.
#
# Canary procedure:
#   1. cp .env.canary .env   (or export each variable below)
#   2. python main.py --safety-check          # must exit GREEN
#   3. python main.py --live-shadow --mode open  # confirm sizing
#   4. python main.py --mode open             # single canary order
#   5. Verify in Alpaca dashboard: buy filled, stop order present
#   6. python main.py --kill-switch           # close position + halt
#   7. python main.py --clear-halt && python main.py --safety-check
#   8. If all pass: restore .env to full £150 profile

# ── Alpaca (live account) ─────────────────────────────────────────────────────
ALPACA_API_KEY=your_live_alpaca_api_key_here
ALPACA_SECRET_KEY=your_live_alpaca_secret_key_here
ALPACA_BASE_URL=https://api.alpaca.markets
TRADING_MODE=live

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Canary caps — $10 ceiling on all order sizes ──────────────────────────────
SMALL_ACCOUNT_MODE=true
MAX_SINGLE_ORDER_USD=10
MAX_DEPLOYED_USD=10
MAX_DAILY_NOTIONAL_USD=10
MAX_ORDERS_PER_RUN=1
MAX_POSITIONS=1

# ── Live confirmation (required for any non-paper session) ────────────────────
LIVE_CONFIRM=I-ACCEPT-REAL-MONEY-RISK

# ── Notifications (optional — leave blank to disable during canary) ───────────
# EMAIL_FROM=
# EMAIL_APP_PASSWORD=
# EMAIL_TO=
# EMAIL_RECIPIENTS=
# DISCORD_WEBHOOK_URL=
